# FermaGen AI - Environment Configuration
# Copy this file to .env and fill in your values
# For production, use a secure secret key generator

# ===================
# Application Mode
# ===================

# Set to false in production
DEBUG=true

# ===================
# Security - REQUIRED
# ===================

# Generate a secure secret key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===================
# Database - PostgreSQL (REQUIRED for production)
# ===================

# For Docker: postgresql+asyncpg://postgres:postgres@postgres:5432/fermagen
# For local: postgresql+asyncpg://postgres:postgres@localhost:5432/fermagen
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/fermagen

# ===================
# Redis Cache (optional but recommended)
# ===================

REDIS_URL=redis://redis:6379/0

# ===================
# Rate Limiting
# ===================

RATE_LIMIT_PER_MINUTE=60

# ===================
# AI API Keys
# ===================

PERPLEXITY_API_KEY=your-perplexity-api-key-here

# NVIDIA ESMFold (3D Protein Structure)
NVIDIA_API_KEY=your-nvidia-api-key

# Firebase Configuration
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_PROJECT_ID=your-firebase-project-id

# ===================
# External APIs (defaults are fine)
# ===================

UNIPROT_BASE_URL=https://rest.uniprot.org
KEGG_BASE_URL=https://rest.kegg.jp
PUBCHEM_BASE_URL=https://pubchem.ncbi.nlm.nih.gov/rest/pug

# ===================
# Frontend (Next.js)
# ===================

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000
